<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <service id="LodinPayment\Core\Checkout\Payment\LodinPaymentHandler">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="logger"/>
            <tag name="shopware.payment.method"/>
        </service>

        <service id="LodinPayment\Controller\LodinReturnController" public="true">
            <tag name="controller.service_arguments"/>
        </service>

        <service id="LodinPayment\Controller\LodinWebhookController" public="true">
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="Shopware\Core\System\StateMachine\StateMachineRegistry"/>
            <argument type="service" id="logger"/>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="LodinPayment\Controller\Success" public="true">
            <tag name="controller.service_arguments"/>
        </service>

        <service id="LodinPayment\Controller\Fail" public="true">
            <tag name="controller.service_arguments"/>
        </service>
    </services>
</container>